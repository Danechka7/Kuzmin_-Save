<Window x:Class="Kuzmin_ГлазкиSave.PriorChange"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение приоритета" 
        Height="160" Width="300" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Введите новый приоритет:" FontSize="14" Margin="0 0 0 10"/>
        <TextBox Name="TBPriority" Grid.Row="1" Height="30" 
                 Margin="0 0 0 10" PreviewTextInput="Number_PreviewTextInput"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OK_Click" Width="80" Height="30" Margin="5"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>